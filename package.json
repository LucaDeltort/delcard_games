		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@tailwindcss/vite": "^4.1.17",
		"@types/node": "^24",
		"globals": "^16.5.0",
		"svelte": "^5.45.6",
		"svelte-check": "^4.3.4",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.1.17",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.48.1",
		"vite": "^7.2.6",
		"vitest": "^4.1.5"
	},
	"dependencies": {
		"bits-ui": "^2.18.0",
		"clsx": "^2.1.1",
		"lucide-svelte": "^1.0.1",
